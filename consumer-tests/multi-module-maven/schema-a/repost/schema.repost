generator javaSdk {
  language = "java"
  output = "../target/generated-sources/repost"
  resourceOutput = "../target/generated-resources/repost"
  packageName = "com.acme.consumer.schemaa"
  clientName = "SchemaAClient"
}
type SchemaA {
  created
}
model SchemaA {
  id String
}
event SchemaACreated {
  type @type(SchemaA.created)
  data SchemaA
  timestamp DateTime
}
