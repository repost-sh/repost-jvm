generator javaSdk {
  language       = "java"
  output         = "../build/generated/sources/repost/javaSdk/java"
  resourceOutput = "../build/generated/resources/repost/javaSdk"
  packageName    = "com.acme.consumer.generated"
  clientName     = "RepostClient"
}

type Order {
  created
}
model Order {
  id String
}
event OrderCreated {
  type @type(Order.created)
  data Order
  timestamp DateTime
}
